# Supabase — Project Settings → API
# Safe to expose to the browser (anon key is RLS-gated):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER expose to the client. Bypasses RLS — used only in trusted
# server code (e.g. admin/maintenance scripts), not in normal request handlers.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic — console.anthropic.com. Server-only. Set a monthly spend limit in
# the console before using this key.
ANTHROPIC_API_KEY=
